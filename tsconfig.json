{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "lib": ["ES6"],
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "noImplicitAny": false,
    "baseUrl": "./",
    "paths": {},
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "miniprogram_npm"
  ]
}