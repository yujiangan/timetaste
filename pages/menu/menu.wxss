/* 菜单页面样式 */
page {
  background: #fff8f3;
  min-height: 100vh;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  padding: 32rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 上传区域 */
.upload-section {
  margin: 0 32rpx;
}

.upload-tip {
  padding: 24rpx;
  background: #f0fdff;
  border: 2rpx solid #91d5ff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #1890ff;
}

.upload-area {
  padding: 48rpx 0;
  background: #fff;
  border: 3rpx dashed #999;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-area.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: #999;
}

/* 加载卡片 - 占有布局 */
.loading-card {
  margin: 20rpx 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  margin-bottom: 16rpx;
}

.spinner-circle {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #ffe4d6;
  border-top: 4rpx solid #ff6b35;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #333;
}

/* 识别结果卡片 - 占有布局 */
.result-card {
  margin: 20rpx 32rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.result-subtitle {
  font-size: 24rpx;
  color: #4caf50;
}

.result-body {
  margin-bottom: 20rpx;
}

.result-row {
  margin-bottom: 20rpx;
}

.result-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.result-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.result-dishes-section {
  margin-bottom: 20rpx;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 14rpx 18rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.dish-name {
  font-size: 26rpx;
  color: #333;
}

.result-tip {
  display: flex;
  align-items: flex-start;
  padding: 14rpx;
  background: #fff8e6;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #ff6b35 0%, #ff8c5a 100%);
  color: #fff;
}

/* 已保存菜单区域 */
.saved-section {
  margin: 20rpx 32rpx;
  border-radius: 16rpx;
  overflow: visible;
  background: transparent;
}

.section-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  margin-bottom: 24rpx;
}

.menu-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.menu-text-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.menu-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.menu-dishes {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.menu-meta {
  font-size: 22rpx;
  color: #999;
}

.menu-delete {
  font-size: 36rpx;
  font-weight: 300;
  color: #999;
  padding: 10rpx;
  flex-shrink: 0;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #999;
}

/* 通用弹窗 */
.modal-mask {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-mask.show {
  display: flex;
}

.modal-content {
  background: #fff;
  margin: 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  width: 70%;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
  display: block;
}

.modal-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #ff6b35;
  color: #fff;
}

/* 成功提示 */
.toast {
  display: none;
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  z-index: 1001;
}

.toast.show {
  display: block;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.toast-text {
  font-size: 28rpx;
  color: #fff;
}
