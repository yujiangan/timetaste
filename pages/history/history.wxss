/* 历史页面样式 */
page {
  background: #fff8f3;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 页面标题 */
.page-header {
  padding: 32rpx;
  background: #fff;
}

.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

/* 历史选择记录标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fafafa;
  border-top: 1rpx solid #eee;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  opacity: 0.4;
}

.clear-btn.active {
  opacity: 1;
}

.clear-btn.active .clear-text {
  color: #ff6b35;
}

.clear-text {
  font-size: 24rpx;
  color: #999;
}

/* 分组历史记录 */
.history-group {
  margin-bottom: 20rpx;
}

.group-label {
  padding: 16rpx 32rpx;
  background: #fafafa;
}

.group-label text {
  font-size: 24rpx;
  color: #999;
}

/* 历史列表 */
.history-list {
  flex: 1;
  padding: 0 32rpx;
}

.history-item {
  display: flex;
  align-items: flex-start;
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.history-emoji {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  font-size: 48rpx;
  flex-shrink: 0;
}

.history-info {
  flex: 1;
}

.history-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 10rpx;
}

.history-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.history-status {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.history-status.adopted {
  background: #e8f5e9;
  color: #4caf50;
}

.history-status.skipped {
  background: #fff0e6;
  color: #ff6b35;
}

.history-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.history-tag-item {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
  color: #666;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 0 48rpx;
}

/* 删除确认弹窗 */
.modal-mask {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-mask.show {
  display: flex;
}

.modal-content {
  background: #fff;
  margin: 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  width: 70%;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
  display: block;
}

.modal-desc {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #ff6b35;
  color: #fff;
}
